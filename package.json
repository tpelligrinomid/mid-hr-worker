{
  "name": "mid-hr-worker",
  "version": "0.1.0",
  "description": "Screens job applicants from Tally via Trigger.dev, creates ClickUp tasks, and pings Slack on qualified fits",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "trigger:dev": "npx trigger.dev@4.3.3 dev",
    "trigger:deploy": "npx trigger.dev@4.3.3 deploy",
    "deploy": "git push && npx trigger.dev@4.3.3 deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.71.2",
    "@trigger.dev/sdk": "4.3.3",
    "apify-client": "2.22.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@trigger.dev/build": "4.3.3",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
