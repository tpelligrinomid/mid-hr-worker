PORT=10000
NODE_ENV=development

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Trigger.dev
TRIGGER_SECRET_KEY=tr_dev_...

# Tally webhook signing secret — set in Tally → Integrations → Webhooks → Signing secret
TALLY_SIGNING_SECRET=

# Apify — LinkedIn profile scraping
APIFY_TOKEN=
# Optional: override the actor ID. Default is dev_fusion~linkedin-profile-scraper.
APIFY_LINKEDIN_ACTOR=dev_fusion~linkedin-profile-scraper

# ClickUp
CLICKUP_API_TOKEN=
CLICKUP_LIST_ID=901702193811
# Custom field ID on the list for the LinkedIn profile URL (get it from ClickUp API: GET /list/{list_id}/field)
CLICKUP_LINKEDIN_FIELD_ID=

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C06630X5ZB8
